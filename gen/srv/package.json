{
  "name": "mcp_servers",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@google/genai": "^1.52.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "solclientjs": "^10.18.3"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "requires": {
        "db": {
          "[development]": {
            "kind": "sqlite"
          },
          "[production]": {
            "kind": "hana"
          }
        }
      },
      "messaging": {
        "kind": "custom",
        "impl": "./srv/service.js"
      },
      "[production]": {
        "auth": "mocked"
      }
    }
  },
  "engines": {
    "node": ">=20"
  }
}